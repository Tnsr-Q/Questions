File: schemas/kernel_registry_list_response.b64.v1.schema.json


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ric.kernel_registry.list_response.b64.v1.schema",
  "title": "KernelRegistry List Response (Base64) v1",
  "type": "object",
  "required": ["registry_version", "kernels"],
  "additionalProperties": false,
  "properties": {
    "registry_version": { "type": "string", "const": "ric.kernel_registry.v1" },
    "kernels": {
      "type": "array",
      "items": { "$ref": "ric.kernel_descriptor.b64.v1.schema" }
    }
  }
}