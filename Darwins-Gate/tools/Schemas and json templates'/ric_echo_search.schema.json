{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ric.echo_search.v1.schema",
  "type": "object",
  "required": ["contract_version", "experiment_id", "data_scope", "hyperparameters", "validation", "reproducibility", "metadata"],
  "properties": {
    "contract_version": { "type": "string", "minLength": 1 },
    "experiment_id": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "required": ["author", "theory", "version", "notes"],
      "properties": {
        "author": { "type": "string" },
        "theory": { "type": "string" },
        "version": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "properties": {
        "h1": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "additionalProperties": true
        },
        "l1": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "data_scope": {
      "type": "object",
      "required": ["event", "detectors", "gps_merger", "window"],
      "properties": {
        "event": { "type": "string" },
        "detectors": {
          "type": "array",
          "items": { "type": "string", "enum": ["H1", "L1", "V1", "K1"] },
          "minItems": 1
        },
        "gps_merger": { "type": "number" },
        "window": {
          "type": "object",
          "required": ["on_source_duration", "off_source_duration", "psd_segment_length"],
          "properties": {
            "on_source_duration": { "type": "number", "exclusiveMinimum": 0 },
            "off_source_duration": { "type": "number", "exclusiveMinimum": 0 },
            "psd_segment_length": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "hyperparameters": {
      "type": "object",
      "required": ["band_hz", "comb", "scan"],
      "properties": {
        "band_hz": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "comb": {
          "type": "object",
          "required": ["delta_f_hz", "tooth_width_hz", "parity"],
          "properties": {
            "delta_f_hz": { "type": "number", "exclusiveMinimum": 0 },
            "tooth_width_hz": { "type": "number", "exclusiveMinimum": 0 },
            "parity": { "type": "string", "enum": ["odd", "even", "none"] }
          },
          "additionalProperties": false
        },
        "scan": {
          "type": "object",
          "required": ["dt_range", "dt_step"],
          "properties": {
            "dt_range": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "dt_step": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["null_tests", "injection"],
      "properties": {
        "null_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["method"],
            "properties": {
              "method": { "type": "string", "enum": ["shifted_comb", "time_slides"] },
              "n_trials": { "type": "integer", "minimum": 1 },
              "n_slides": { "type": "integer", "minimum": 1 },
              "slide_step": { "type": "number", "exclusiveMinimum": 0 },
              "shift_hz_range": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              },
              "shift_strategy": { "type": "string", "enum": ["uniform", "grid"] }
            },
            "additionalProperties": true
          }
        },
        "injection": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "snr_levels": {
              "type": "array",
              "items": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "reproducibility": {
      "type": "object",
      "required": ["seed", "require_hash_check"],
      "properties": {
        "seed": { "type": "integer" },
        "require_hash_check": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}