1) Kernel Registry response schema
1.1 schemas/kernel_descriptor.v1.schema.json

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ric.kernel_descriptor.v1.schema",
  "title": "KernelDescriptor v1",
  "type": "object",
  "required": ["id", "title", "capability", "schemas"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "object",
      "required": ["name", "version", "contract_version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "contract_version": { "type": "string", "minLength": 1 }
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },

    "capability": {
      "type": "object",
      "required": ["supports_cluster_compute", "supports_browser_viz", "supports_browser_preview_compute"],
      "additionalProperties": false,
      "properties": {
        "supports_cluster_compute": { "type": "boolean" },
        "supports_browser_viz": { "type": "boolean" },
        "supports_browser_preview_compute": { "type": "boolean" }
      }
    },

    "schemas": {
      "type": "object",
      "required": ["parameters_json_schema", "ui_hints_json_schema"],
      "additionalProperties": false,
      "properties": {
        "parameters_json_schema": {
          "type": "object",
          "description": "Draft 2020-12 JSON Schema that validates manifest.parameters"
        },
        "ui_hints_json_schema": {
          "type": "object",
          "description": "Draft 2020-12 JSON Schema that validates ui_hints for this kernel"
        },
        "results_json_schema": {
          "type": "object",
          "description": "Optional: validates results JSON emitted by the kernel"
        }
      }
    },

    "ui_hints": {
      "type": "object",
      "description": "Optional: actual UI hints payload (must validate against ui_hints_json_schema)"
    },

    "examples": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_parameters_example": { "type": "object" },
        "ui_hints_example": { "type": "object" }
      }
    }
  }
}