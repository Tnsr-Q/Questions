2) UI Hints spec (shared across kernels)

This is the key to your “browser constructs in real time” flow.

2.1 schemas/ui_hints.v1.schema.json


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ric.ui_hints.v1.schema",
  "title": "UI Hints v1",
  "type": "object",
  "required": ["ui_hints_version", "kernel", "layout", "fields"],
  "additionalProperties": false,
  "properties": {
    "ui_hints_version": { "type": "string", "const": "ric.ui_hints.v1" },

    "kernel": {
      "type": "object",
      "required": ["name", "contract_version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "contract_version": { "type": "string" }
      }
    },

    "layout": {
      "type": "object",
      "required": ["groups"],
      "additionalProperties": false,
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "paths"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "paths": {
                "type": "array",
                "items": { "type": "string", "description": "JSON pointer-ish path into parameters, e.g. /hyperparameters/comb/delta_f_hz" }
              }
            }
          }
        }
      }
    },

    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "widget"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },

          "label": { "type": "string" },
          "help": { "type": "string" },
          "units": { "type": "string" },

          "widget": {
            "type": "string",
            "enum": ["text", "textarea", "number", "slider", "toggle", "select", "multiselect", "object", "array", "file_input"]
          },

          "format": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "digits": { "type": "integer", "minimum": 0, "maximum": 12 },
              "scientific": { "type": "boolean" },
              "log_scale": { "type": "boolean" }
            }
          },

          "constraints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number", "exclusiveMinimum": 0 },
              "recommended": { "type": "boolean" }
            }
          },

          "visibility": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "advanced": { "type": "boolean" },
              "show_if": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "op", "value"],
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string" },
                    "op": { "type": "string", "enum": ["==", "!=", ">", ">=", "<", "<=", "in"] },
                    "value": {}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}